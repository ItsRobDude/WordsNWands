{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordsnwands/content/schemas/generation/encounter-archetype-blueprint.schema.json",
  "title": "EncounterArchetypeBlueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blueprint_id",
    "display_label",
    "allowed_tiers",
    "encounter_type",
    "pressure_style",
    "spell_identity",
    "allowed_spell_payloads",
    "allowed_matchup_pair_pool_ids",
    "allowed_habitat_tags",
    "profile_overrides",
    "prohibited_combination_flags"
  ],
  "properties": {
    "blueprint_id": { "type": "string", "minLength": 1 },
    "display_label": { "type": "string", "minLength": 1 },
    "allowed_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["gentle", "standard", "challenging", "boss", "event"]
      }
    },
    "encounter_type": { "type": "string", "enum": ["standard", "boss", "event"] },
    "pressure_style": {
      "type": "string",
      "enum": [
        "soft_nuisance",
        "board_reorder",
        "temporary_blockage",
        "element_disruption",
        "boss_escalation"
      ]
    },
    "spell_identity": { "type": "string", "minLength": 1 },
    "allowed_spell_payloads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["template_id", "primitive_kind"],
        "properties": {
          "template_id": { "type": "string", "minLength": 1 },
          "primitive_kind": {
            "type": "string",
            "enum": ["apply_tile_state", "shift_row", "shift_column", "chained"]
          }
        }
      }
    },
    "allowed_matchup_pair_pool_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_habitat_tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "profile_overrides": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weakness_hit_rate_delta",
        "wand_incidence_delta",
        "soot_exposure_delta",
        "target_casts_to_defeat_delta",
        "target_spell_count_on_win_delta"
      ],
      "properties": {
        "weakness_hit_rate_delta": { "type": "number" },
        "wand_incidence_delta": { "type": "number" },
        "soot_exposure_delta": { "type": "number" },
        "target_casts_to_defeat_delta": { "type": "number" },
        "target_spell_count_on_win_delta": { "type": "number" }
      }
    },
    "prohibited_combination_flags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
