{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordsnwands/content/schemas/generation/encounter-generation-request.schema.json",
  "title": "EncounterGenerationRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "generator_version",
    "generator_mode",
    "generation_seed",
    "content_version_target",
    "validation_snapshot_version_target",
    "battle_rules_version_target",
    "board_generator_version_target",
    "encounter_count",
    "habitat_pool_ids",
    "blueprint_ids",
    "target_tier",
    "target_fail_rate_band",
    "board_profile_ids",
    "allow_name_generation_from_bank",
    "allow_flavor_generation_from_bank",
    "output_scope"
  ],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "generator_version": { "const": "structured_generation_v1" },
    "generator_mode": {
      "type": "string",
      "enum": ["draft_generate_freeze_v1", "runtime_seeded_trial_v1"]
    },
    "generation_seed": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "content_version_target": { "type": "string", "minLength": 1 },
    "validation_snapshot_version_target": { "type": "string", "minLength": 1 },
    "battle_rules_version_target": { "type": "string", "minLength": 1 },
    "board_generator_version_target": { "type": "string", "minLength": 1 },
    "encounter_count": { "type": "integer", "minimum": 1, "maximum": 12 },
    "habitat_pool_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "blueprint_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "target_tier": {
      "type": "string",
      "enum": ["gentle", "standard", "challenging", "boss", "event"]
    },
    "target_fail_rate_band": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "board_profile_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "allow_name_generation_from_bank": { "type": "boolean" },
    "allow_flavor_generation_from_bank": { "type": "boolean" },
    "output_scope": {
      "type": "string",
      "enum": ["draft_only", "draft_and_freeze_candidate"]
    }
  }
}
