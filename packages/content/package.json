{
  "name": "@words-n-wands/content",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,js,mjs,json,md}\"",
    "lint": "prettier --check \"src/**/*.{ts,js,mjs,json,md}\" && tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cd ../.. && node --test packages/content/src/**/*.test.js",
    "build": "tsc -p tsconfig.json --noEmit"
  }
}
