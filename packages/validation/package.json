{
  "name": "@words-n-wands/validation",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,js,mjs,json,md}\"",
    "lint": "prettier --check \"src/**/*.{ts,js,mjs,json,md}\" && tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test --test-isolation=none --import ../../scripts/register-typescript-test-hooks.mjs \"src/**/*.test.js\" \"src/**/*.test.ts\"",
    "profile:has-playable-word": "node --expose-gc --experimental-strip-types --import ../../scripts/register-typescript-test-hooks.mjs ../../scripts/profile-has-playable-word.mjs",
    "build": "tsc -p tsconfig.json --noEmit"
  }
}
