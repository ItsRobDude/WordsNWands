{
  "name": "@words-n-wands/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "lint": "pnpm exec prettier --check \"{index.js,metro.config.cjs,app.config.ts,app/**/*.tsx,src/**/*.{ts,tsx},tsconfig.json}\" && tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test --test-isolation=none --import ../../scripts/register-typescript-test-hooks.mjs \"src/**/*.test.ts\"",
    "build": "expo export --platform android"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.12"
  }
}
