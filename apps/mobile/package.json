{
  "name": "@words-n-wands/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "lint": "prettier --check \"{App.tsx,metro.config.js,src/**/*.{ts,tsx},tsconfig.json}\" && tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test --test-isolation=none --import ../../scripts/register-typescript-test-hooks.mjs \"src/**/*.test.ts\"",
    "build": "expo export --platform android"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-sqlite": "^55.0.15",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "zustand": "^5.0.12"
  }
}
