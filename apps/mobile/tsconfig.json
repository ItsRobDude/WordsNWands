{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": [
    "./app/**/*.ts",
    "./app/**/*.tsx",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./.expo/types/**/*.ts",
    "./expo-env.d.ts",
    "./**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
