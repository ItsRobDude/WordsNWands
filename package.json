{
  "name": "words-n-wands-tools",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "content:generate:encounters": "node packages/content/src/generation/cli/generateEncounters.js",
    "validation:snapshot:import-frequency-bootstrap": "node scripts/import-frequency-bootstrap-candidates.mjs",
    "validation:snapshot:seed-inputs": "node scripts/seed-validation-snapshot-inputs.mjs",
    "validation:snapshot:sync-review-sheet": "node scripts/sync-validation-review-sheet.mjs",
    "validation:snapshot:build": "node scripts/build-validation-snapshot.mjs",
    "lint": "pnpm -r --workspace-concurrency=1 --if-present run lint",
    "test": "pnpm -r --workspace-concurrency=1 --if-present run test",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present run typecheck",
    "build": "pnpm -r --workspace-concurrency=1 --if-present run build",
    "format": "pnpm -r --workspace-concurrency=1 --if-present run format",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
